<%- include('../layouts/header_ed2030') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="/css/ed2030.css">

<div class="container py-5">
    <!-- Header of the course -->
    <div class="text-center mb-5">
        <span class="badge bg-danger px-3 py-2 fs-6 mb-2">Luyện Tập Ngữ Văn Lớp 8</span>
        <h1 class="display-5 fw-bold text-dark">Bài học: Từ ngữ địa phương</h1>
        <p class="lead text-muted">Chương trình Ngữ Văn Lớp 8 - Học tập tương tác dựa trên Thuyết Kiến Tạo</p>
    </div>

    <!-- Progress Tracker Steps -->
    <div class="row justify-content-center mb-5">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between position-relative progress-steps-container">
                <div class="progress-line" id="steps-progress-bar" style="width: 36%;"></div>
                <div class="step-item completed" id="step-0">
                    <div class="step-icon"><i class="bi bi-info-circle"></i></div>
                    <div class="step-label">Giới thiệu</div>
                </div>
                <div class="step-item completed" id="step-1">
                    <div class="step-icon"><i class="bi bi-play-btn"></i></div>
                    <div class="step-label">1. Xem Video</div>
                </div>
                <div class="step-item active" id="step-2">
                    <div class="step-icon"><i class="bi bi-grid-3x3-gap"></i></div>
                    <div class="step-label">2. Màn 1: Ghép đôi</div>
                </div>
                <div class="step-item locked" id="step-3">
                    <div class="step-icon"><i class="bi bi-chat-left-quote"></i></div>
                    <div class="step-label">3. Màn 2: Hội thoại</div>
                </div>
                <div class="step-item locked" id="step-4">
                    <div class="step-icon"><i class="bi bi-cursor-fill"></i></div>
                    <div class="step-label">4. Màn 3: Nhận diện</div>
                </div>
                <div class="step-item locked" id="step-5">
                    <div class="step-icon"><i class="bi bi-trophy"></i></div>
                    <div class="step-label">Kết quả</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content Container with dynamic views -->
    <div class="row justify-content-center">
        <div class="col-lg-10">
            
            <!-- SECTION 2: GAME MÀN 1 (DRAG AND DROP) -->
            <div class="card p-4 p-md-5 shadow-sm border-0 mb-4 section-card active-section" id="section-2">
                <h3 class="fw-bold mb-3 text-danger-custom"><i class="bi bi-grid-3x3-gap me-2"></i>Màn chơi 1: Ghép đôi hình ảnh và Từ địa phương</h3>
                <p class="text-secondary mb-4"><strong>Nhiệm vụ (Bloom: Hiểu):</strong> Kéo các thẻ từ địa phương ở bên trái và thả vào đúng ô chứa hình ảnh của đồ vật/hoa quả tương ứng ở bên phải (Miền Bắc).</p>
                
                <div class="row g-4 my-3">
                    <!-- Left: Draggable Words -->
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded shadow-sm border h-100">
                            <h5 class="fw-bold text-dark text-center mb-3">Thẻ từ địa phương</h5>
                            <div class="d-flex flex-md-column flex-wrap justify-content-center gap-3" id="draggables-container">
                                <!-- Generated Dynamically -->
                            </div>
                        </div>
                    </div>
                    
                    <!-- Right: Drop Zones (Images) -->
                    <div class="col-md-8">
                        <div class="row g-3" id="dropzones-container">
                            <!-- Generated Dynamically -->
                        </div>
                    </div>
                </div>

                <div id="drag-feedback" class="alert alert-success text-center d-none mt-3"></div>

                <div class="d-flex justify-content-between mt-4">
                    <a href="/ed2030/xem_video" class="btn btn-outline-secondary px-4 py-2"><i class="bi bi-arrow-left me-2"></i>Quay lại</a>
                    <div class="d-flex gap-2">
                        <button class="btn btn-warning px-4 py-2 fw-bold" id="drag-submit-btn" disabled onclick="submitDragGame()">Nộp bài</button>
                        <a href="/ed2030/man_2" class="btn btn-primary px-4 py-2 fw-bold d-none" id="drag-next-btn">Vào Màn 2: Hội thoại <i class="bi bi-arrow-right ms-2"></i></a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script src="/js/ed2030/common.js?v=3"></script>
<script src="/js/ed2030/man_1.js?v=3"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        initDragAndDropGame();
    });
</script>

<%- include('../layouts/footer') %>
