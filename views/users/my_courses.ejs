<%- include('../layouts/header') %>

<div class="container py-5 min-vh-100">
    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
        <div class="bg-danger bg-opacity-10 text-danger p-3 rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
            <i class="bi bi-journal-bookmark-fill fs-3"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-1 text-uppercase text-dark">Khóa học của tôi</h2>
            <p class="text-muted mb-0">Theo dõi tiến độ và tiếp tục hành trình học tập của bạn.</p>
        </div>
    </div>
    
    <% if (myCourses && myCourses.length > 0) { %>
        <div class="row g-4">
            <% myCourses.forEach(course => { %>
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden course-card transition-all" style="transition: transform 0.3s ease, box-shadow 0.3s ease;" onmouseover="this.style.transform='translateY(-5px)'; this.classList.add('shadow');" onmouseout="this.style.transform='translateY(0)'; this.classList.remove('shadow');">
                        <div class="position-relative">
                            <img src="<%= course.cover_image %>" class="card-img-top" alt="<%= course.title %>" style="height: 200px; object-fit: cover;">
                            <% const progress = course.total_lessons > 0 ? Math.round((course.completed_lessons / course.total_lessons) * 100) : 0; %>
                            <% if (progress === 100) { %>
                                <div class="position-absolute top-0 end-0 m-3">
                                    <span class="badge bg-success rounded-pill px-3 py-2 fw-bold shadow"><i class="bi bi-trophy-fill me-1"></i> Hoàn thành</span>
                                </div>
                            <% } %>
                        </div>
                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title fw-bold text-dark mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; min-height: 48px;">
                                <%= course.title %>
                            </h5>
                            
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted fw-bold">Tiến độ (<%= course.completed_lessons %>/<%= course.total_lessons %>)</small>
                                    <small class="text-success fw-bold fs-6"><%= progress %>%</small>
                                </div>
                                <div class="progress mb-4" style="height: 10px; border-radius: 10px;">
                                    <div class="progress-bar bg-success progress-bar-striped <%= progress < 100 ? 'progress-bar-animated' : '' %>" role="progressbar" aria-valuenow="<%= progress %>" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                
                                <% if (progress === 100) { %>
                                    <a href="/ac2070/course/<%= course.slug %>" class="btn btn-outline-success w-100 rounded-pill fw-bold py-2">Ôn tập lại <i class="bi bi-arrow-repeat ms-1"></i></a>
                                <% } else { %>
                                    <a href="/ac2070/course/<%= course.slug %>" class="btn btn-danger w-100 rounded-pill fw-bold py-2 shadow-sm">Tiếp tục học <i class="bi bi-play-circle-fill ms-1"></i></a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center py-5 my-5 bg-light rounded-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle shadow-sm mb-4" style="width: 100px; height: 100px;">
                <i class="bi bi-journal-x fs-1 text-danger opacity-75"></i>
            </div>
            <h3 class="fw-bold text-dark mb-2">Bạn chưa đăng ký khóa học nào</h3>
            <p class="text-muted fs-5 mb-4">Hãy khám phá các khóa học thú vị và bắt đầu hành trình học tập của bạn.</p>
            <a href="/" class="btn btn-danger px-5 py-3 rounded-pill fw-bold fs-5 shadow-sm">Khám phá khóa học ngay <i class="bi bi-arrow-right ms-2"></i></a>
        </div>
    <% } %>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Gán chiều rộng cho thanh tiến độ dựa trên thuộc tính aria-valuenow để tránh lỗi CSS linter trong file EJS
        const progressBars = document.querySelectorAll('.progress-bar');
        progressBars.forEach(bar => {
            const val = bar.getAttribute('aria-valuenow');
            if (val !== null) {
                bar.style.width = val + '%';
            }
        });
    });
</script>

<%- include('../layouts/footer') %>
