<%- include('../layouts/header') %>
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/ac2070/users/dashboard" class="text-decoration-none">Người dùng</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Thùng rác</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-1"><i class="bi bi-trash text-danger me-2"></i> Thùng Rác Người Dùng</h2>
            <p class="text-muted mb-0">Tài khoản đã bị xóa mềm khỏi hệ thống.</p>
        </div>
        <a href="/ac2070/users/dashboard" class="btn btn-outline-secondary fw-bold rounded-pill px-4 shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="ps-4">ID</th>
                            <th scope="col">Họ và tên</th>
                            <th scope="col">Email</th>
                            <th scope="col">Ngày xóa</th>
                            <th scope="col" class="text-center">Khôi phục</th>
                            <th scope="col" class="text-center pe-4">Xóa vĩnh viễn</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (users && users.length > 0) { %>
                            <% users.forEach(userItem => { %>
                                <tr>
                                    <td class="ps-4 text-muted fw-bold">#<%= userItem.id %></td>
                                    <td>
                                        <div class="fw-bold text-dark"><%= userItem.full_name %></div>
                                    </td>
                                    <td>
                                        <span class="text-muted"><%= userItem.email %></span>
                                    </td>
                                    <td>
                                        <small class="text-muted"><%= new Date(userItem.deleted_at).toLocaleString('vi-VN') %></small>
                                    </td>
                                    <td class="text-center">
                                        <form action="/ac2070/users/<%= userItem.id %>/restore" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success border-0 rounded-circle" title="Khôi phục">
                                                <i class="bi bi-arrow-counterclockwise fs-5"></i>
                                            </button>
                                        </form>
                                    </td>
                                    <td class="text-center pe-4">
                                        <button class="btn btn-sm btn-outline-danger border-0 rounded-circle" title="Xóa vĩnh viễn" 
                                            data-bs-toggle="modal" data-bs-target="#forceDeleteUserModal" 
                                            onclick="setForceDeleteUserForm('/ac2070/users/<%= userItem.id %>/force-delete', '<%= userItem.email %>')">
                                            <i class="bi bi-trash-fill fs-5"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    Thùng rác trống.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Xác nhận Xóa vĩnh viễn -->
<div class="modal fade" id="forceDeleteUserModal" tabindex="-1" aria-labelledby="forceDeleteUserModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow rounded-4">
      <div class="modal-header border-bottom-0">
        <h5 class="modal-title fw-bold text-danger" id="forceDeleteUserModalLabel">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> Cảnh báo: Xóa vĩnh viễn tài khoản
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body fs-5 text-center py-4">
        Bạn có thực sự muốn xóa vĩnh viễn tài khoản <strong id="forceDeleteUserEmail" class="text-dark"></strong> không?<br>
        <span class="fs-6 text-danger fw-bold mt-2 d-block">Tài khoản này và mọi lịch sử học tập liên quan sẽ bị xóa sạch khỏi hệ thống. KHÔNG THỂ KHÔI PHỤC!</span>
      </div>
      <div class="modal-footer border-top-0 d-flex justify-content-center gap-3 pb-4">
        <form id="forceDeleteUserForm" method="POST" action="">
            <button type="submit" class="btn btn-danger btn-lg px-4 fw-bold">Xóa Vĩnh Viễn</button>
        </form>
        <button type="button" class="btn btn-secondary btn-lg px-4 fw-bold" data-bs-dismiss="modal">Hủy</button>
      </div>
    </div>
  </div>
</div>

<script>
    function setForceDeleteUserForm(actionUrl, userEmail) {
        document.getElementById('forceDeleteUserForm').action = actionUrl;
        document.getElementById('forceDeleteUserEmail').innerText = userEmail;
    }
</script>
<%- include('../layouts/footer') %>
