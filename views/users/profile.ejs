<%- include('../layouts/header') %>

<div class="container py-5">
    <div class="row">
        <div class="col-lg-4 mb-4">
            <!-- Profile Sidebar -->
            <div class="card border-0 shadow-sm rounded-4 text-center p-4">
                <div class="mb-3 mt-3">
                    <% if (userProfile.role === 'admin') { %>
                        <div class="bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center fw-bold shadow" style="width: 100px; height: 100px; font-size: 40px;">
                            <i class="bi bi-shield-lock-fill"></i>
                        </div>
                    <% } else { %>
                        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center fw-bold shadow" style="width: 100px; height: 100px; font-size: 40px;">
                            <%= userProfile.full_name.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                </div>
                <h4 class="fw-bold mb-1"><%= userProfile.full_name %></h4>
                <p class="text-muted mb-3"><%= userProfile.email %></p>
                <div class="mb-4">
                    <% if (userProfile.role === 'admin') { %>
                        <span class="badge bg-danger rounded-pill px-3 py-2"><i class="bi bi-star-fill me-1"></i> Admin</span>
                    <% } else { %>
                        <span class="badge bg-info text-dark rounded-pill px-3 py-2"><i class="bi bi-person-fill me-1"></i> Học viên</span>
                    <% } %>
                </div>
                <hr>
                <ul class="list-unstyled text-start mb-0">
                    <li class="mb-2"><i class="bi bi-calendar3 text-muted me-2"></i> Tham gia: <span class="fw-bold"><%= new Date(userProfile.created_at).toLocaleDateString('vi-VN') %></span></li>
                </ul>
            </div>
        </div>
        
        <div class="col-lg-8">
            <!-- Alerts -->
            <% if (success === 'update_info') { %>
                <div class="alert alert-success d-flex align-items-center rounded-3 shadow-sm mb-4" role="alert">
                    <i class="bi bi-check-circle-fill flex-shrink-0 me-2 fs-5"></i>
                    <div>Cập nhật thông tin thành công!</div>
                </div>
            <% } %>
            <% if (success === 'change_password') { %>
                <div class="alert alert-success d-flex align-items-center rounded-3 shadow-sm mb-4" role="alert">
                    <i class="bi bi-check-circle-fill flex-shrink-0 me-2 fs-5"></i>
                    <div>Đổi mật khẩu thành công!</div>
                </div>
            <% } %>

            <% if (error === 'empty_name') { %>
                <div class="alert alert-danger d-flex align-items-center rounded-3 shadow-sm mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2 fs-5"></i>
                    <div>Tên không được để trống!</div>
                </div>
            <% } %>
            <% if (error === 'password_mismatch') { %>
                <div class="alert alert-danger d-flex align-items-center rounded-3 shadow-sm mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2 fs-5"></i>
                    <div>Mật khẩu mới và Nhập lại mật khẩu không khớp!</div>
                </div>
            <% } %>
            <% if (error === 'wrong_password') { %>
                <div class="alert alert-danger d-flex align-items-center rounded-3 shadow-sm mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2 fs-5"></i>
                    <div>Mật khẩu hiện tại không đúng!</div>
                </div>
            <% } %>
            <% if (error === 'update_failed' || error === 'change_password_failed') { %>
                <div class="alert alert-danger d-flex align-items-center rounded-3 shadow-sm mb-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2 fs-5"></i>
                    <div>Có lỗi xảy ra, vui lòng thử lại sau!</div>
                </div>
            <% } %>

            <!-- Thông tin cơ bản -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold"><i class="bi bi-person-lines-fill text-primary me-2"></i> Thông tin cơ bản</h5>
                </div>
                <div class="card-body p-4">
                    <form action="/ac2070/profile/update" method="POST">
                        <div class="row mb-3">
                            <label for="email" class="col-sm-3 col-form-label fw-bold text-muted">Email đăng nhập</label>
                            <div class="col-sm-9">
                                <input type="email" class="form-control bg-light" id="email" value="<%= userProfile.email %>" readonly disabled>
                            </div>
                        </div>
                        <div class="row mb-4">
                            <label for="full_name" class="col-sm-3 col-form-label fw-bold">Họ và tên <span class="text-danger">*</span></label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="full_name" name="full_name" value="<%= userProfile.full_name %>" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-9 offset-sm-3">
                                <button type="submit" class="btn btn-primary fw-bold px-4 rounded-pill">Lưu thông tin</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Đổi mật khẩu -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold"><i class="bi bi-key-fill text-warning me-2"></i> Đổi mật khẩu</h5>
                </div>
                <div class="card-body p-4">
                    <form action="/ac2070/profile/change-password" method="POST">
                        <div class="row mb-3">
                            <label for="current_password" class="col-sm-4 col-form-label fw-bold">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                            <div class="col-sm-8">
                                <input type="password" class="form-control" id="current_password" name="current_password" required placeholder="Nhập mật khẩu đang sử dụng">
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label for="new_password" class="col-sm-4 col-form-label fw-bold">Mật khẩu mới <span class="text-danger">*</span></label>
                            <div class="col-sm-8">
                                <input type="password" class="form-control" id="new_password" name="new_password" required placeholder="Mật khẩu tối thiểu 6 ký tự">
                            </div>
                        </div>
                        <div class="row mb-4">
                            <label for="confirm_password" class="col-sm-4 col-form-label fw-bold">Nhập lại mật khẩu mới <span class="text-danger">*</span></label>
                            <div class="col-sm-8">
                                <input type="password" class="form-control" id="confirm_password" name="confirm_password" required placeholder="Xác nhận lại mật khẩu mới">
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-8 offset-sm-4">
                                <button type="submit" class="btn btn-warning text-dark fw-bold px-4 rounded-pill">Đổi mật khẩu</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            
        </div>
    </div>
</div>

<%- include('../layouts/footer') %>
