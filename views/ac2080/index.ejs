<%- include('../layouts/header') %>

    <link rel="stylesheet" href="/ac2080/css/ac2080.css">


    <div class="container py-5">
        <!-- Breadcrumbs / Top Header -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-secondary">Trang
                                chủ</a></li>
                        <li class="breadcrumb-item active text-primary" aria-current="page">AC2080</li>
                    </ol>
                </nav>
                <h1 class="h2 fw-bold text-dark mb-0">HUST Gold Miner (Đào Vàng Bách Khoa)</h1>
                <p class="text-muted mb-0">Học phần: AC2080 - Trò chơi số và tương tác 1</p>
            </div>
            <span class="badge bg-primary-custom px-3 py-2 fs-6">Đồ án Game GDevelop</span>
        </div>

        <!-- Game Arena Row (Full Width centered, max-width 1280px) -->
        <div class="row justify-content-center mb-5">
            <div class="col-12">
                <div class="game-arena-wrapper">
                    <!-- Arcade Style Title Bar -->
                    <div class="game-header-bar text-white">
                        <div class="d-flex align-items-center">
                            <span class="game-status-dot"></span>
                            <span class="fw-bold small text-uppercase tracking-wider">HUST Gold Miner Arena</span>
                        </div>
                        <span class="badge bg-secondary text-light small px-2 py-1">GDevelop v5</span>
                    </div>

                    <!-- Iframe Window -->
                    <div class="game-container-iframe">
                        <iframe id="hust-game-iframe" src="<%= gameUrl %>" allowfullscreen="true"
                            scrolling="no"></iframe>
                    </div>

                    <!-- Arcade Bottom Controls -->
                    <div class="game-controls-bar">
                        <button class="btn btn-sm btn-outline-light d-flex align-items-center" onclick="reloadGame()">
                            <i class="bi bi-arrow-clockwise me-1"></i> Tải lại Game
                        </button>
                        <button class="btn btn-sm btn-outline-light d-flex align-items-center"
                            onclick="toggleFullscreen()">
                            <i class="bi bi-fullscreen me-1"></i> Toàn màn hình
                        </button>
                        <a href="<%= gameUrl %>" target="_blank"
                            class="btn btn-sm btn-primary d-flex align-items-center text-white">
                            <i class="bi bi-box-arrow-up-right me-1"></i> Chơi Tab mới <i
                                class="bi bi-chevron-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Wiki and Sidebar Row -->
        <div class="row">
            <!-- Main Column: Game Wiki -->
            <div class="col-lg-8">
                <div class="card bg-surface p-4 shadow-sm border-0 mb-4">
                    <h3 class="wiki-section-title text-dark">Cốt truyện & Cơ chế game</h3>
                    <p class="text-secondary lead fs-6">
                        Trong vai một sinh viên Bách Khoa HUST đầy nhiệt huyết, bạn phải đối mặt với thử thách lớn nhất
                        thời sinh viên:
                        <strong>Kiếm đủ điểm số GPA, tích lũy tín chỉ và sống sót qua các kỳ thi để ra trường!</strong>
                    </p>
                    <p class="text-secondary">
                        Bằng cách thả móc gắp kéo tương tự lối chơi Đào Vàng truyền thống, người chơi sẽ cố gắng gắp lấy
                        các môn học
                        và các mốc điểm số mong muốn. Tuy nhiên, đời sống sinh viên không chỉ có học tập – bạn sẽ phải
                        né tránh các
                        yếu tố xao nhãng cám dỗ để bảo toàn điểm số của mình.
                    </p>
                </div>

                <!-- Items section -->
                <div class="card bg-surface p-4 shadow-sm border-0 mb-4">
                    <h3 class="wiki-section-title text-dark">Hệ thống Vật phẩm trong game</h3>

                    <!-- Category 1: Môn học (Tín chỉ) -->
                    <h5 class="text-primary mt-3 mb-3 fw-bold"><i class="bi bi-book-half me-2"></i>Các Môn Học Đại Cương
                        (Tín chỉ)</h5>
                    <p class="text-muted small">Mỗi môn học kéo được sẽ giúp tích lũy số lượng tín chỉ tương ứng để tiến
                        gần hơn đến điều kiện ra trường.</p>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-good">
                                    <i class="bi bi-activity"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Giải Tích</h6>
                                    <p class="mb-0 text-secondary small">Ký hiệu tích phân màu xanh lá cây.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-good">
                                    <i class="bi bi-dice-5"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Xác Suất Thống Kê</h6>
                                    <p class="mb-0 text-secondary small">Hình ảnh quân xúc xắc may rủi.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-good">
                                    <i class="bi bi-cpu"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Vật Lý Đại Cương</h6>
                                    <p class="mb-0 text-secondary small">Ký hiệu hạt nhân nguyên tử.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-good">
                                    <i class="bi bi-laptop"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Tin Học Đại Cương</h6>
                                    <p class="mb-0 text-secondary small">Hình ảnh máy tính xách tay (Laptop).</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-good">
                                    <i class="bi bi-journal-bookmark-fill"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Triết Học Mác - Lênin</h6>
                                    <p class="mb-0 text-secondary small">Cuốn sách dày chứa đựng những tư tưởng triết
                                        học đại cương.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Category 2: GPA -->
                    <h5 class="text-success mb-3 fw-bold"><i class="bi bi-award me-2"></i>Thang Điểm Tích Lũy (GPA)</h5>
                    <p class="text-muted small">Điểm số GPA của bạn sẽ thay đổi tùy thuộc vào điểm chữ kéo được. Hãy
                        nâng mức điểm từ 2.0 ban đầu lên các mốc cao hơn.</p>
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-info">B</div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Điểm B (3.0)</h6>
                                    <p class="mb-0 text-secondary small">Yêu cầu hoàn thành Màn 1.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-info">B+</div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Điểm B+ (3.5)</h6>
                                    <p class="mb-0 text-secondary small">Yêu cầu hoàn thành Màn 2.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-info">A</div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Điểm A (4.0)</h6>
                                    <p class="mb-0 text-secondary small">Yêu cầu hoàn thành Màn 3.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Category 3: Distractions -->
                    <h5 class="text-danger mb-3 fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Yếu tố xao
                        nhãng (Vật cản)</h5>
                    <p class="text-muted small">Cảnh báo! Những vật phẩm có viền màu Đỏ hoặc Đen đại diện cho sự xao
                        nhãng, sẽ trừ 1 điểm GPA nếu bạn vô tình gắp trúng.</p>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-bad">
                                    <i class="bi bi-instagram"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Mạng xã hội</h6>
                                    <p class="mb-0 text-secondary small">Instagram, TikTok, Facebook...</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-bad">
                                    <i class="bi bi-controller"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Video Games</h6>
                                    <p class="mb-0 text-secondary small">Cơn nghiện game thâu đêm suốt sáng.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Category 4: Shop & Upgrades -->
                    <h5 class="text-warning mb-3 fw-bold"><i class="bi bi-shop me-2"></i>Cửa hàng BKSHOP & Vật phẩm bổ
                        trợ</h5>
                    <p class="text-muted small">Kéo túi tiền để thu thập ngân sách học tập. Khi kết thúc màn chơi, bạn
                        sẽ được ghé qua cửa hàng BKSHOP để mua đồ nâng cấp.</p>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-neutral">
                                    <i class="bi bi-wallet2"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Túi tiền</h6>
                                    <p class="mb-0 text-secondary small">Vật phẩm tích lũy ngân lượng.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-neutral">
                                    <i class="bi bi-lightning-charge-fill"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Móc kéo nhanh</h6>
                                    <p class="mb-0 text-secondary small">Tăng tốc độ kéo vật phẩm lên.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-neutral">
                                    <i class="bi bi-scissors"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Dây cắt (Thuốc nổ)</h6>
                                    <p class="mb-0 text-secondary small">Huỷ kéo vật phẩm xao nhãng.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="d-flex align-items-center p-3 bg-white border rounded shadow-sm">
                                <div class="game-item-badge bg-item-neutral">
                                    <i class="bi bi-hourglass-split"></i>
                                </div>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Đóng băng thời gian (10 giây)</h6>
                                    <p class="mb-0 text-secondary small">Dừng thời gian của màn chơi giúp kéo thêm môn
                                        học.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar Column: Game goals & dev team -->
            <div class="col-lg-4">
                <!-- Game Level Targets Card -->
                <div class="card border-0 shadow-sm p-4 bg-surface mb-4">
                    <h4 class="wiki-section-title text-dark">Yêu cầu 3 Màn Chơi</h4>
                    <div class="d-flex flex-column gap-3">
                        <!-- Level 1 -->
                        <div class="card bg-white border-0 shadow-sm level-card p-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="mb-0 fw-bold text-primary">Màn 1</h5>
                                <span class="badge bg-secondary text-white">1m30s</span>
                            </div>
                            <div class="text-secondary small">
                                <div class="d-flex justify-content-between mb-1">
                                    <span>Tín chỉ tối thiểu:</span>
                                    <span class="fw-bold">12 Tín chỉ (6 môn)</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span>GPA Mục tiêu:</span>
                                    <span class="fw-bold text-success">3.0 (Điểm B)</span>
                                </div>
                            </div>
                        </div>
                        <!-- Level 2 -->
                        <div class="card bg-white border-0 shadow-sm level-card p-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="mb-0 fw-bold text-primary">Màn 2</h5>
                                <span class="badge bg-secondary text-white">3m00s</span>
                            </div>
                            <div class="text-secondary small">
                                <div class="d-flex justify-content-between mb-1">
                                    <span>Tín chỉ tối thiểu:</span>
                                    <span class="fw-bold">24 Tín chỉ (10 môn)</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span>GPA Mục tiêu:</span>
                                    <span class="fw-bold text-success">3.5 (Điểm B+)</span>
                                </div>
                            </div>
                        </div>
                        <!-- Level 3 -->
                        <div class="card bg-white border-0 shadow-sm level-card p-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="mb-0 fw-bold text-primary">Màn 3</h5>
                                <span class="badge bg-secondary text-white">4m00s</span>
                            </div>
                            <div class="text-secondary small">
                                <div class="d-flex justify-content-between mb-1">
                                    <span>Tín chỉ tối thiểu:</span>
                                    <span class="fw-bold">40 Tín chỉ (20 môn)</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span>GPA Mục tiêu:</span>
                                    <span class="fw-bold text-success">4.0 (Điểm A)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Basic Info / Game developer team Card -->
                <div class="card border-0 shadow-sm p-4 bg-surface mb-4">
                    <h4 class="wiki-section-title text-dark">Nhóm thực hiện</h4>
                    <div class="list-group list-group-flush bg-transparent">
                        <div
                            class="list-group-item bg-transparent px-0 py-2 d-flex justify-content-between align-items-center">
                            <span class="text-secondary">Học Phần</span>
                            <span class="fw-bold text-dark">AC2080</span>
                        </div>
                        <div
                            class="list-group-item bg-transparent px-0 py-2 d-flex justify-content-between align-items-center">
                            <span class="text-secondary">Game Developer</span>
                            <span class="fw-bold text-dark">Nguyễn Hoàng Trung</span>
                        </div>
                        <div
                            class="list-group-item bg-transparent px-0 py-2 d-flex justify-content-between align-items-center">
                            <span class="text-secondary">Game Designer</span>
                            <span class="fw-bold text-dark">Phạm Thanh Phước Long</span>
                        </div>
                        <div
                            class="list-group-item bg-transparent px-0 py-2 d-flex justify-content-between align-items-center">
                            <span class="text-secondary">Game Designer</span>
                            <span class="fw-bold text-dark">Hà Huyền Trang</span>
                        </div>
                        <div
                            class="list-group-item bg-transparent px-0 py-2 d-flex justify-content-between align-items-center">
                            <span class="text-secondary">Game Artist</span>
                            <span class="fw-bold text-dark">Nguyễn Sĩ Tuấn</span>
                        </div>
                    </div>
                </div>

                <!-- Instruction Card -->
                <div class="card border-0 shadow-sm p-4 bg-surface">
                    <h4 class="wiki-section-title text-dark">Hướng dẫn điều khiển</h4>
                    <ul class="text-secondary small ps-3">
                        <li class="mb-2">Sử dụng nút <strong>Space</strong> để thả móc gắp.</li>
                        <li class="mb-2">Gắp các môn học để tăng số lượng môn (tín chỉ).</li>
                        <li class="mb-2">Gắp các điểm chữ để cải thiện điểm số tích lũy GPA.</li>
                        <li class="mb-2">Tránh gắp phải biểu tượng Mạng xã hội để không bị trừ GPA.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Simple Script for handling Game player controls -->
    <script>
        function reloadGame() {
            const iframe = document.getElementById('hust-game-iframe');
            if (iframe) {
                iframe.src = iframe.src;
            }
        }

        function toggleFullscreen() {
            const iframe = document.getElementById('hust-game-iframe');
            if (iframe) {
                if (iframe.requestFullscreen) {
                    iframe.requestFullscreen();
                } else if (iframe.mozRequestFullScreen) { /* Firefox */
                    iframe.mozRequestFullScreen();
                } else if (iframe.webkitRequestFullscreen) { /* Chrome, Safari and Opera */
                    iframe.webkitRequestFullscreen();
                } else if (iframe.msRequestFullscreen) { /* IE/Edge */
                    iframe.msRequestFullscreen();
                }
            }
        }
    </script>

    <%- include('../layouts/footer') %>