<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/jpg" href="/images/Anh_Trung.jpg">
    <title>Bài Tập Lớn</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/main.css">
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark-custom py-3 border-bottom">
            <div class="container">
                <!-- Left: Logo -->
                <a class="navbar-brand d-flex align-items-center" href="/">
                    <img src="/images/logobk.png" alt="BK Logo" class="logo-img">
                </a>

                <!-- Toggler button for Mobile -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Navbar Collapse Container -->
                <div class="collapse navbar-collapse" id="navbarNav">
                    <!-- Center: Links -->
                    <ul class="navbar-nav mx-auto text-center">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom mx-3" href="/ac2030"
                                title="Khai Thác Thông Tin đa phương tiện">AC2030</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom mx-3" href="/ac2070"
                                title="Thiết kế và lập trình Web">AC2070</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom mx-3" href="/ac2080"
                                title="Trò chơi số và tương tác 1">AC2080</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom mx-3" href="/ed2030/gioi_thieu" title="Thiết kế dạy học">ED2030</a>
                        </li>
                    </ul>

                    <!-- Right: User Avatar / Login -->
                    <div class="d-flex align-items-center justify-content-center mt-3 mt-lg-0 ms-auto">
                        <% if (locals.user) { %>
                            <div class="dropdown">
                                <a class="btn btn-dark dropdown-toggle border-0 d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="background: transparent;">
                                    <div class="user-info text-end me-2 d-none d-lg-block">
                                        <div class="user-name fw-bold text-white"><%= user.full_name %></div>
                                        <div class="user-id text-light" style="font-size: 0.8rem;"><%= user.role === 'admin' ? 'Quản trị viên' : 'Học viên' %></div>
                                    </div>
                                    <div class="avatar-container">
                                        <img src="/images/Anh_Trung.jpg" alt="User Avatar" class="user-avatar rounded-circle" style="width: 40px; height: 40px; object-fit: cover;">
                                    </div>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    <li><a class="dropdown-item fw-bold" href="/ac2070/profile"><i class="bi bi-person-badge me-2"></i> Hồ sơ của tôi</a></li>
                                    <li><a class="dropdown-item fw-bold" href="/ac2070/profile/courses"><i class="bi bi-journal-bookmark-fill me-2"></i> Khóa học của tôi</a></li>
                                    <% if (user.role === 'admin') { %>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><h6 class="dropdown-header text-uppercase">Admin Panel</h6></li>
                                        <li><a class="dropdown-item text-primary fw-bold" href="/ac2070/course/dashboard"><i class="bi bi-speedometer2 me-1"></i> Quản lý khóa học</a></li>
                                        <li><a class="dropdown-item text-primary fw-bold" href="/ac2070/users/dashboard"><i class="bi bi-people-fill me-1"></i> Quản lý người dùng</a></li>
                                    <% } %>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="/ac2070/auth/logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
                                </ul>
                            </div>
                        <% } else { %>
                            <a href="/ac2070/auth/login" class="btn btn-outline-light rounded-pill px-4 fw-bold">Đăng nhập</a>
                        <% } %>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main>