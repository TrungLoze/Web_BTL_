<%- include('../../layouts/header') %>
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/ac2070/course/dashboard" class="text-decoration-none">Khóa học</a></li>
                    <li class="breadcrumb-item active" aria-current="page"><%= course.title %></li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-1"><i class="bi bi-journal-text text-success me-2"></i> Quản lý Bài Học</h2>
            <div class="d-flex align-items-center gap-3">
                <p class="text-muted mb-0">Khóa học: <%= course.title %></p>
                <a href="/ac2070/course/<%= course.slug %>/lessons/dashboard/rebin" class="text-decoration-none text-danger fw-bold"><i class="bi bi-trash"></i> Thùng rác bài học</a>
            </div>
        </div>
        <a href="/ac2070/course/<%= course.slug %>/lessons/create" class="btn btn-success fw-bold rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Thêm bài học mới
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="text-center" style="width: 10%">Thứ tự</th>
                            <th scope="col" style="width: 35%">Tên bài học</th>
                            <th scope="col" style="width: 25%">Video/Thời lượng</th>
                            <th scope="col" class="text-center" style="width: 15%">Sửa</th>
                            <th scope="col" class="text-center" style="width: 15%">Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (lessons && lessons.length > 0) { %>
                            <% lessons.forEach((lesson) => { %>
                                <tr>
                                    <td class="text-center fw-bold text-muted">Bài <%= lesson.lesson_order %></td>
                                    <td>
                                        <div class="fw-bold text-dark"><%= lesson.title %></div>
                                        <small class="text-muted">ID: <%= lesson.id %></small>
                                    </td>
                                    <td>
                                        <div><i class="bi bi-play-circle text-danger me-1"></i> <a href="<%= lesson.video_url %>" target="_blank" class="text-decoration-none">Link Video</a></div>
                                        <small class="text-muted"><i class="bi bi-clock me-1"></i> <%= lesson.duration || 'Chưa cập nhật' %></small>
                                    </td>
                                    <td class="text-center">
                                        <a href="/ac2070/course/<%= course.slug %>/lessons/<%= lesson.id %>/edit" class="btn btn-sm btn-outline-primary border-0 rounded-circle" title="Sửa">
                                            <i class="bi bi-pencil-square fs-5"></i>
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger border-0 rounded-circle" title="Xóa" 
                                            data-bs-toggle="modal" data-bs-target="#deleteLessonModal" 
                                            onclick="setDeleteLessonForm('/ac2070/course/<%= course.slug %>/lessons/<%= lesson.id %>/delete', '<%= lesson.title %>')">
                                            <i class="bi bi-trash fs-5"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    Khóa học này chưa có bài học nào. Hãy thêm bài học đầu tiên!
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Xác nhận Xóa -->
<div class="modal fade" id="deleteLessonModal" tabindex="-1" aria-labelledby="deleteLessonModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow rounded-4">
      <div class="modal-header border-bottom-0">
        <h5 class="modal-title fw-bold text-danger" id="deleteLessonModalLabel">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> Xác nhận xóa
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body fs-5 text-center py-4">
        Bạn có chắc chắn muốn xóa bài học <strong id="deleteLessonName" class="text-dark"></strong> không?<br>
        <span class="fs-6 text-muted">Hành động này không thể hoàn tác!</span>
      </div>
      <div class="modal-footer border-top-0 d-flex justify-content-center gap-3 pb-4">
        <form id="deleteLessonForm" method="POST" action="">
            <button type="submit" class="btn btn-danger btn-lg px-4 fw-bold">Xóa</button>
        </form>
        <button type="button" class="btn btn-secondary btn-lg px-4 fw-bold" data-bs-dismiss="modal">Hủy</button>
      </div>
    </div>
  </div>
</div>

<script>
    function setDeleteLessonForm(actionUrl, lessonTitle) {
        document.getElementById('deleteLessonForm').action = actionUrl;
        document.getElementById('deleteLessonName').innerText = lessonTitle;
    }
</script>
<%- include('../../layouts/footer') %>
