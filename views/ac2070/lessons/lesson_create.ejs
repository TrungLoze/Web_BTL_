<%- include('../../layouts/header') %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-4">
                    <li class="breadcrumb-item"><a href="/ac2070/course/dashboard" class="text-decoration-none">Khóa học</a></li>
                    <li class="breadcrumb-item"><a href="/ac2070/course/<%= course.slug %>/lessons/dashboard" class="text-decoration-none"><%= course.title %></a></li>
                    <li class="breadcrumb-item active" aria-current="page">Thêm bài học mới</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold mb-2">Thêm Bài Học Mới</h2>
                        <p class="text-muted">Khóa học: <span class="fw-bold text-dark"><%= course.title %></span></p>
                    </div>

                    <% if (error) { %>
                        <div class="alert alert-danger d-flex align-items-center rounded-3 mb-4" role="alert">
                            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
                            <div><%= error %></div>
                        </div>
                    <% } %>

                    <form action="/ac2070/course/<%= course.slug %>/lessons/create" method="POST">
                        <div class="mb-4">
                            <label for="title" class="form-label fw-bold">Tên bài học <span class="text-danger">*</span></label>
                            <input type="text" class="form-control form-control-lg bg-light border-0" id="title" name="title" required placeholder="Nhập tên bài học (VD: Bài 1: Giới thiệu HTML)">
                        </div>

                        <div class="mb-4">
                            <label for="video_url" class="form-label fw-bold">Link Video <span class="text-danger">*</span></label>
                            <input type="url" class="form-control form-control-lg bg-light border-0" id="video_url" name="video_url" required placeholder="Nhập đường dẫn Video (Youtube/Vimeo/...)">
                        </div>

                        <div class="mb-4">
                            <label for="duration" class="form-label fw-bold">Thời lượng</label>
                            <input type="text" class="form-control form-control-lg bg-light border-0" id="duration" name="duration" placeholder="VD: 10:45">
                            <small class="text-muted mt-2 d-block"><i class="bi bi-magic"></i> Có thể bỏ trống nếu là link Youtube, hệ thống sẽ tự động lấy thời lượng!</small>
                        </div>

                        <div class="mb-4">
                            <label for="lesson_order" class="form-label fw-bold">Vị trí bài học <span class="text-danger">*</span></label>
                            <select name="lesson_order" id="lesson_order" class="form-select form-select-lg bg-light border-0">
                                <option value="<%= maxOrder + 1 %>" selected>Thêm vào cuối cùng (Bài <%= maxOrder + 1 %>)</option>
                                <% if (lessons && lessons.length > 0) { %>
                                    <% lessons.forEach(lesson => { %>
                                        <option value="<%= lesson.lesson_order %>">Chèn vào trước Bài <%= lesson.lesson_order %>: <%= lesson.title %></option>
                                    <% }) %>
                                <% } %>
                            </select>
                            <small class="text-muted mt-2 d-block"><i class="bi bi-info-circle"></i> Việc chèn bài học vào giữa sẽ tự động đẩy số thứ tự các bài học phía sau lên 1.</small>
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-success btn-lg fw-bold rounded-pill shadow-sm">
                                <i class="bi bi-save me-2"></i> Lưu bài học
                            </button>
                            <a href="/ac2070/course/<%= course.slug %>/lessons/dashboard" class="btn btn-light btn-lg fw-bold rounded-pill">
                                Hủy bỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../layouts/footer') %>
