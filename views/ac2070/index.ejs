<%- include('../layouts/header') %>
<link rel="stylesheet" href="/ac2070/css/ac2070.css">

<div class="container py-5">
    <!-- Hero Banner -->
    <section class="hero-banner-custom text-white p-5 mb-5 d-flex flex-column justify-content-center">
        <div>
            <div class="hero-badge mb-3">⚡ Gia nhập hơn 1 triệu học sinh trên toàn quốc</div>
            <h1 class="display-4 fw-bold mb-3">Box-Fed <br><span class="highlight-red">HUST.</span></h1>
            <p class="lead text-light mb-4" style="max-width: 550px;">
                Hệ thống các khóa học trực tuyến sử dụng công cụ đặc biệt dành riêng cho sinh viên ngành công nghệ giáo dục
            </p>
            <div class="d-flex align-items-center gap-3">
                <button class="btn-primary-custom">KHÁM PHÁ KHÓA HỌC &rarr;</button>
                <a href="#" class="btn-play-custom">▶</a>
            </div>
        </div>
    </section>

    <!-- Khóa học nổi bật -->
    <section class="course-section">
        <h2 class="fw-bold mb-4" style="color: #111827;">Khóa học nổi bật</h2>
        
        <div class="row g-4">
            <% if (courses && courses.length > 0) { %>
                <% courses.forEach(course => { %>
                    <div class="col-12 col-md-6 col-lg-3 d-flex">
                        <div class="course-card-custom w-100 d-flex flex-column">
                            <!-- Hiển thị ảnh cover, nếu trong DB trống thì dùng ảnh mặc định -->
                            <img src="<%= course.cover_image || 'https://images.unsplash.com/photo-1606326608606-aa0b62935f2b?q=80&w=600&auto=format&fit=crop' %>" 
                                 alt="<%= course.title %>" class="course-cover-custom">
                            
                            <div class="p-3 d-flex flex-column flex-grow-1">
                                <h3 class="h5 fw-bold mb-2 text-dark"><%= course.title %></h3>
                                <p class="text-secondary small mb-3 flex-grow-1"><%= course.description %></p>
                                
                                <a href="/ac2070/course/<%= course.slug %>" class="text-decoration-none mt-auto">
                                    <button class="btn-course-custom">Bắt đầu học ngay</button>
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Chưa có khóa học nào được hiển thị. Vui lòng thêm dữ liệu vào bảng `courses` trong database.</p>
                </div>
            <% } %>
        </div>
    </section>
</div>

<%- include('../layouts/footer') %>
