<%- include('../../layouts/header') %>
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="bi bi-speedometer2 text-danger me-2"></i> Quản lý Khóa Học</h2>
            <div class="d-flex align-items-center gap-3">
                <p class="text-muted mb-0">Dành riêng cho Quản trị viên (Admin)</p>
                <a href="/ac2070/course/dashboard/rebin" class="text-decoration-none text-danger fw-bold"><i class="bi bi-trash"></i> Thùng rác</a>
            </div>
        </div>
        <a href="/ac2070/course/create" class="btn btn-danger fw-bold rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Tạo khóa mới
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="text-center" style="width: 5%">STT</th>
                            <th scope="col" style="width: 25%">Tên khóa học</th>
                            <th scope="col" style="width: 30%">Mô tả</th>
                            <th scope="col" class="text-center" style="width: 10%">Bài học</th>
                            <th scope="col" class="text-center" style="width: 15%">Sửa</th>
                            <th scope="col" class="text-center" style="width: 15%">Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (courses && courses.length > 0) { %>
                            <% courses.forEach((course, index) => { %>
                                <tr>
                                    <td class="text-center fw-bold text-muted"><%= index + 1 %></td>
                                    <td>
                                        <div class="fw-bold text-dark"><%= course.title %></div>
                                        <small class="text-muted">Slug: <%= course.slug %></small>
                                    </td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 300px;" title="<%= course.description %>">
                                            <%= course.description || 'Chưa có mô tả' %>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <a href="/ac2070/course/<%= course.slug %>/lessons/dashboard" class="btn btn-sm btn-outline-success border-0 rounded-circle" title="Quản lý bài học">
                                            <i class="bi bi-journal-text fs-5"></i>
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <a href="/ac2070/course/<%= course.slug %>/edit" class="btn btn-sm btn-outline-primary border-0 rounded-circle" title="Sửa">
                                            <i class="bi bi-pencil-square fs-5"></i>
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger border-0 rounded-circle" title="Xóa" 
                                            data-bs-toggle="modal" data-bs-target="#deleteCourseModal" 
                                            onclick="setDeleteForm('/ac2070/course/<%= course.slug %>/delete', '<%= course.title %>')">
                                            <i class="bi bi-trash fs-5"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    Chưa có khóa học nào. Hãy tạo khóa học đầu tiên!
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Xác nhận Xóa -->
<div class="modal fade" id="deleteCourseModal" tabindex="-1" aria-labelledby="deleteCourseModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow rounded-4">
      <div class="modal-header border-bottom-0">
        <h5 class="modal-title fw-bold text-danger" id="deleteCourseModalLabel">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> Xác nhận xóa
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body fs-5 text-center py-4">
        Bạn có chắc chắn muốn xóa khóa học <strong id="deleteCourseName" class="text-dark"></strong> không?<br>
        <span class="fs-6 text-muted">Hành động này không thể hoàn tác!</span>
      </div>
      <div class="modal-footer border-top-0 d-flex justify-content-center gap-3 pb-4">
        <form id="deleteCourseForm" method="POST" action="">
            <button type="submit" class="btn btn-danger btn-lg px-4 fw-bold">Xóa</button>
        </form>
        <button type="button" class="btn btn-secondary btn-lg px-4 fw-bold" data-bs-dismiss="modal">Hủy</button>
      </div>
    </div>
  </div>
</div>

<script>
    function setDeleteForm(actionUrl, courseTitle) {
        document.getElementById('deleteCourseForm').action = actionUrl;
        document.getElementById('deleteCourseName').innerText = courseTitle;
    }

    document.addEventListener("DOMContentLoaded", function() {
        const progressBars = document.querySelectorAll('.progress-bar');
        progressBars.forEach(bar => {
            const val = bar.getAttribute('aria-valuenow');
            if (val !== null) {
                bar.style.width = val + '%';
            }
        });
    });
</script>
<%- include('../../layouts/footer') %>
