<%- include('../../layouts/header') %>
    <link rel="stylesheet" href="/ac2070/css/course_detail.css">
    
          <!-- -Check người dùng đã đăng nhập chưa,phải đăng nhập rồi thì mới xem bài học được -->
     <div id="auth-check" data-logged-in="<%= typeof user !== 'undefined' && user ? 'true' : 'false' %>"></div>


    <div class="container py-4">
        <!-- Breadcrumb / Nút quay lại -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Trang chủ</a>
                </li>
                <li class="breadcrumb-item"><a href="/ac2070/course" class="text-decoration-none text-muted">Khóa học</a></li>
                <li class="breadcrumb-item active" aria-current="page">
                    <%= course.title %>
                </li>
            </ol>
        </nav>

        <div class="row g-4">
            <!-- Khu vực chính bên trái: Intro hoặc Video Player -->
            <div class="col-lg-8">

                <!-- 1. INTRO CARD (Hiển thị ban đầu) -->
                <div id="intro-content" class="card border-0 shadow-sm rounded-4 p-4 p-md-5 h-100">
                    <div class="d-flex align-items-center gap-3 mb-4 pb-4 border-bottom">
                        <div class="d-flex align-items-center justify-content-center rounded-3 bg-danger bg-opacity-10 text-danger fs-2"
                            style="width: 60px; height: 60px;">
                            <i class="bi bi-mortarboard-fill"></i>
                        </div>
                        <div>
                            <h2 class="fw-bold mb-2 text-uppercase fs-3">GIỚI THIỆU KHÓA HỌC <%= course.title %>
                            </h2>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border">E-LEARNING</span>
                                <span
                                    class="badge bg-warning bg-opacity-10 text-warning border border-warning-subtle">+5
                                    SAO KHI HOÀN THÀNH</span>
                            </div>
                        </div>
                    </div>

                    <div class="card-body p-0">
                        <h5 class="fw-bold mb-3">Mô tả khóa học</h5>
                        <p class="fs-5 text-muted mb-4">
                            <%= course.description
                                || 'Khóa học này sẽ giúp bạn làm chủ các kỹ năng cần thiết một cách nhanh chóng và hiệu quả.'
                                %>
                        </p>

                        <h5 class="fw-bold mb-3">Bạn sẽ nhận được gì?</h5>
                        <ul
                            class="list-group list-group-flush border-start border-danger border-4 rounded-end-3 mb-5 shadow-sm">
                            <li class="list-group-item bg-light border-0 py-3">1. Hoàn thành toàn bộ video bài giảng:
                                +150 sao.</li>
                            <li class="list-group-item bg-light border-0 py-3">2. Vượt qua các bài kiểm tra trắc nghiệm:
                                +500 sao.</li>
                            <li class="list-group-item bg-light border-0 py-3">3. Hoàn thành đồ án cuối khóa: +350 sao.
                            </li>
                        </ul>

                        <% if (user) { %>
                            <% if (isEnrolled) { %>
                                <div class="mt-4">
                                    <h6 class="fw-bold mb-2">Tiến độ học tập (<%= completedLessonsCount %>/<%= lessons.length %> bài)</h6>
                                    <div class="progress" style="height: 20px;">
                                        <div class="progress-bar bg-success progress-bar-striped progress-bar-animated" id="course-progress-bar" role="progressbar" aria-valuenow="<%= progressPercent %>" aria-valuemin="0" aria-valuemax="100"><%= progressPercent %>%</div>
                                    </div>
                                </div>
                                <button id="btn-start-course" class="btn btn-start-course px-4 py-3 rounded-pill fw-bold fs-5 w-100 w-md-auto mt-4">
                                    <i class="bi bi-play-circle-fill me-2"></i> Tiếp tục học
                                </button>
                            <% } else { %>
                                <form action="/ac2070/course/<%= course.slug %>/enroll" method="POST" class="mt-4">
                                    <button type="submit" class="btn btn-start-course px-4 py-3 rounded-pill fw-bold fs-5 w-100 w-md-auto">
                                        <i class="bi bi-person-plus-fill me-2"></i> Đăng ký khóa học
                                    </button>
                                </form>
                            <% } %>
                        <% } else { %>
                            <a href="/ac2070/auth/login" class="btn btn-start-course px-4 py-3 rounded-pill fw-bold fs-5 w-100 w-md-auto mt-4 text-decoration-none text-center">
                                <i class="bi bi-box-arrow-in-right me-2"></i> Đăng nhập để bắt đầu học
                            </a>
                        <% } %>
                    </div>
                </div>

                <!-- 2. VIDEO PLAYER (Hiển thị khi bấm bài học) -->
                <div id="video-content" class="card border-0 shadow-sm rounded-4 overflow-hidden"
                    style="display: none;" data-enrolled="<%= typeof isEnrolled !== 'undefined' ? isEnrolled : 'false' %>" data-slug="<%= course.slug %>">
                    <!-- Trình phát video (Tỉ lệ 16:9 Bootstrap) -->
                    <div class="ratio ratio-16x9 video-player-wrapper bg-dark">
                        <iframe id="main-video-player" src=""
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                            allowfullscreen></iframe>
                    </div>

                    <!-- Thông tin bài đang phát -->
                    <div
                        class="card-body p-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                        <h4 id="now-playing-title" class="fw-bold mb-0 text-dark">Đang phát: Tên bài học</h4>
                        <div class="d-flex gap-2">
                            <button id="btn-complete-lesson" class="btn btn-light border fw-bold text-secondary" style="display: none;">
                                <i class="bi bi-check-circle me-1"></i> Đánh dấu hoàn thành
                            </button>
                            <button id="btn-next-lesson" class="btn btn-primary px-4 py-2 fw-bold text-white shadow rounded-pill" style="display: none; transition: transform 0.2s;">
                                Chuyển bài tiếp theo <i class="bi bi-arrow-right-circle-fill ms-2 fs-5 align-middle"></i>
                            </button>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Khu vực thanh bên phải: Danh sách bài học -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 sticky-top" style="top: 20px;">
                    <h5 class="fw-bold mb-4 pb-3 border-bottom border-2 border-light text-uppercase">Nội dung khóa học
                    </h5>

                    <!-- Danh sách bài học -->
                    <ul class="lesson-list list-unstyled mb-0">
                        <% if (lessons && lessons.length > 0) { %>
                            <% lessons.forEach((lesson, index) => { %>
                                <% const isCompleted = (typeof completedLessonIds !== 'undefined' && completedLessonIds.includes(lesson.id)); %>
                                <li class="lesson-item bg-white border rounded-3 p-3 mb-3 d-flex align-items-center"
                                    data-video="<%= lesson.embed_url %>" data-id="<%= lesson.id %>" data-completed="<%= isCompleted ? 'true' : 'false' %>">
                                    <div class="lesson-index shadow-sm me-3 <%= isCompleted ? 'bg-success text-white' : 'text-muted' %>">
                                        <% if (isCompleted) { %><i class="bi bi-check"></i><% } else { %><%= index + 1 %><% } %>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-1 text-dark"><%= lesson.title %></h6>
                                        <span class="lesson-time"><i class="bi bi-play-circle me-1"></i> <%= lesson.duration || '00:00' %></span>
                                    </div>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center text-muted py-4">
                                Khóa học này chưa có bài học nào.
                            </div>
                        <% } %>
                    </ul>
                </div>
            </div>
        </div>
    </div>
     
    <!-- Hiển thị thông báo đăng nhập để bắt đầu bài học -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
  <div id="loginToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="toast-header bg-danger text-white">
      <strong class="me-auto">Thông báo</strong>
      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body">
      Vui lòng <a href="/ac2070/auth/login" class="text-danger fw-bold">đăng nhập</a> để bắt đầu học nhé!
    </div>
  </div>
</div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const introContent = document.getElementById('intro-content');
            const videoContent = document.getElementById('video-content');
            const videoPlayer = document.getElementById('main-video-player');
            const nowPlayingTitle = document.getElementById('now-playing-title');
            const btnStart = document.getElementById('btn-start-course');
            const lessonItems = document.querySelectorAll('.lesson-item');

            // Hàm phát video
            function playVideo(videoUrl, lessonElement) {
                // Đổi giao diện
                introContent.style.display = 'none';
                videoContent.style.display = 'block';

                // Đổi link iframe
                videoPlayer.src = videoUrl;

                // Xóa active cũ, thêm active mới
                const currentActive = document.querySelector('.lesson-item.active');
                if (currentActive) currentActive.classList.remove('active', 'border-danger');

                lessonElement.classList.add('active', 'border-danger');

                // Cập nhật tiêu đề đang phát
                const lessonTitle = lessonElement.querySelector('h6').innerText;
                nowPlayingTitle.innerText = `Đang phát: ${lessonTitle}`;

                // Check trạng thái bài học để hiện nút 
                const isEnrolled = videoContent.getAttribute('data-enrolled') === 'true';
                const isCompleted = lessonElement.getAttribute('data-completed') === 'true';
                const lessonId = lessonElement.getAttribute('data-id');
                
                const btnComplete = document.getElementById('btn-complete-lesson');
                const btnNext = document.getElementById('btn-next-lesson');

                if (isEnrolled && btnComplete) {
                    btnComplete.style.display = 'inline-block';
                    btnComplete.setAttribute('data-lesson-id', lessonId);
                    if (isCompleted) {
                        btnComplete.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i> Đã hoàn thành';
                        btnComplete.className = 'btn btn-success text-white fw-bold';
                        btnComplete.disabled = true;
                    } else {
                        btnComplete.innerHTML = '<i class="bi bi-check-circle me-1"></i> Đánh dấu hoàn thành';
                        btnComplete.className = 'btn btn-light border fw-bold text-secondary';
                        btnComplete.disabled = false;
                    }
                } else if (btnComplete) {
                    btnComplete.style.display = 'none';
                }

                const nextLesson = lessonElement.nextElementSibling;
                if (btnNext) {
                    if (nextLesson) {
                        btnNext.style.display = 'inline-block';
                        btnNext.onclick = function() {
                            nextLesson.click();
                        };
                    } else {
                        btnNext.style.display = 'none';
                    }
                }

                // Cuộn màn hình đến video trên mobile
                if (window.innerWidth < 992) {
                    videoContent.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            }

            // Bắt đầu khóa học -> mở bài đầu tiên
            if (btnStart) {
                btnStart.addEventListener('click', function () {
                    if (lessonItems.length > 0) {
                        const firstLesson = lessonItems[0];
                        const videoUrl = firstLesson.getAttribute('data-video');
                        playVideo(videoUrl, firstLesson);
                    }
                });
            }

            
            // Click vào từng bài học
            lessonItems.forEach(item => {
                item.addEventListener('click', function () {
                    const isLoggedIn = document.getElementById('auth-check').getAttribute('data-logged-in') === 'true';
        
                    if (!isLoggedIn) {
                        // 1. Lấy phần tử Toast
                        const toastEl = document.getElementById('loginToast');
                        // 2. Khởi tạo và hiển thị Toast (Bootstrap 5)
                        const toast = new bootstrap.Toast(toastEl);
                        toast.show();
                        return; // Dừng lại, không phát video
                    }

                    // Nếu đã đăng nhập, mới cho phép xem
                    const videoUrl = this.getAttribute('data-video');
                    playVideo(videoUrl, this);
                });
            });

            // Xử lý nút đánh dấu hoàn thành
            const btnComplete = document.getElementById('btn-complete-lesson');
            if (btnComplete) {
                btnComplete.addEventListener('click', async function() {
                    const lessonId = this.getAttribute('data-lesson-id');
                    const slug = videoContent.getAttribute('data-slug');
                    
                    try {
                        const response = await fetch(`/ac2070/course/${slug}/lessons/${lessonId}/complete`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' }
                        });
                        
                        const result = await response.json();
                        if (result.success) {
                            // Cập nhật UI
                            const activeLesson = document.querySelector('.lesson-item.active');
                            if (activeLesson) {
                                activeLesson.setAttribute('data-completed', 'true');
                                const indexBadge = activeLesson.querySelector('.lesson-index');
                                indexBadge.className = 'lesson-index shadow-sm me-3 bg-success text-white';
                                indexBadge.innerHTML = '<i class="bi bi-check"></i>';
                                
                                // Đổi trạng thái nút
                                this.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i> Đã hoàn thành';
                                this.className = 'btn btn-success text-white fw-bold';
                                this.disabled = true;
                                
                                // Reload trang nếu muốn cập nhật thanh tiến độ nhanh (hoặc có thể viết JS update % ở client)
                                // window.location.reload(); 
                            }
                        } else {
                            alert(result.message || 'Có lỗi xảy ra khi hoàn thành bài học');
                        }
                    } catch (err) {
                        console.error(err);
                        alert('Đã có lỗi xảy ra');
                    }
                });
            }

            // Gán chiều rộng cho thanh tiến độ dựa trên thuộc tính aria-valuenow để tránh lỗi CSS linter trong file EJS
            const progressBar = document.getElementById('course-progress-bar');
            if (progressBar) {
                progressBar.style.width = progressBar.getAttribute('aria-valuenow') + '%';
            }
        });
    </script>

    <%- include('../../layouts/footer') %>