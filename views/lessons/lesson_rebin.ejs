<%- include('../layouts/header') %>
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="/ac2070/course/dashboard" class="text-decoration-none">Khóa học</a></li>
                    <li class="breadcrumb-item"><a href="/ac2070/course/<%= course.slug %>/lessons/dashboard" class="text-decoration-none"><%= course.title %></a></li>
                    <li class="breadcrumb-item active" aria-current="page">Thùng rác</li>
                </ol>
            </nav>
            <h2 class="fw-bold mb-1"><i class="bi bi-trash text-danger me-2"></i> Thùng Rác Bài Học</h2>
            <p class="text-muted mb-0">Khóa học: <%= course.title %></p>
        </div>
        <a href="/ac2070/course/<%= course.slug %>/lessons/dashboard" class="btn btn-outline-secondary fw-bold rounded-pill px-4 shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="text-center" style="width: 10%">Thứ tự</th>
                            <th scope="col" style="width: 40%">Tên bài học</th>
                            <th scope="col" style="width: 20%">Ngày xóa</th>
                            <th scope="col" class="text-center" style="width: 15%">Khôi phục</th>
                            <th scope="col" class="text-center" style="width: 15%">Xóa vĩnh viễn</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (lessons && lessons.length > 0) { %>
                            <% lessons.forEach((lesson) => { %>
                                <tr>
                                    <td class="text-center fw-bold text-muted">Bài <%= lesson.lesson_order %></td>
                                    <td>
                                        <div class="fw-bold text-dark"><%= lesson.title %></div>
                                        <small class="text-muted">ID: <%= lesson.id %></small>
                                    </td>
                                    <td>
                                        <div class="text-muted"><%= new Date(lesson.deleted_at).toLocaleString('vi-VN') %></div>
                                    </td>
                                    <td class="text-center">
                                        <form action="/ac2070/course/<%= course.slug %>/lessons/<%= lesson.id %>/restore" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-success border-0 rounded-circle" title="Khôi phục">
                                                <i class="bi bi-arrow-counterclockwise fs-5"></i>
                                            </button>
                                        </form>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger border-0 rounded-circle" title="Xóa vĩnh viễn" 
                                            data-bs-toggle="modal" data-bs-target="#forceDeleteLessonModal" 
                                            onclick="setForceDeleteLessonForm('/ac2070/course/<%= course.slug %>/lessons/<%= lesson.id %>/force-delete', '<%= lesson.title %>')">
                                            <i class="bi bi-trash-fill fs-5"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    Thùng rác trống.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal Xác nhận Xóa vĩnh viễn -->
<div class="modal fade" id="forceDeleteLessonModal" tabindex="-1" aria-labelledby="forceDeleteLessonModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow rounded-4">
      <div class="modal-header border-bottom-0">
        <h5 class="modal-title fw-bold text-danger" id="forceDeleteLessonModalLabel">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> Cảnh báo: Xóa vĩnh viễn
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body fs-5 text-center py-4">
        Bạn có thực sự muốn xóa vĩnh viễn bài học <strong id="forceDeleteLessonName" class="text-dark"></strong> không?<br>
        <span class="fs-6 text-danger fw-bold mt-2 d-block">Mọi dữ liệu học tập của học viên liên quan đến bài học này cũng sẽ bị xóa và KHÔNG THỂ khôi phục!</span>
      </div>
      <div class="modal-footer border-top-0 d-flex justify-content-center gap-3 pb-4">
        <form id="forceDeleteLessonForm" method="POST" action="">
            <button type="submit" class="btn btn-danger btn-lg px-4 fw-bold">Xóa Vĩnh Viễn</button>
        </form>
        <button type="button" class="btn btn-secondary btn-lg px-4 fw-bold" data-bs-dismiss="modal">Hủy</button>
      </div>
    </div>
  </div>
</div>

<script>
    function setForceDeleteLessonForm(actionUrl, lessonTitle) {
        document.getElementById('forceDeleteLessonForm').action = actionUrl;
        document.getElementById('forceDeleteLessonName').innerText = lessonTitle;
    }
</script>
<%- include('../layouts/footer') %>
